# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ---- Alpaca (paper trading) --------------------------------------------------
# Get keys at: alpaca.markets -> Paper Trading -> API Keys
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true          # set to false ONLY after weeks of paper testing

# ---- Discord -----------------------------------------------------------------
# Set up a bot at: discord.com/developers/applications
# Enable "Message Content Intent" under Bot settings
# Invite bot to your server with Read Messages + Message History permissions
DISCORD_BOT_TOKEN=your_bot_token_here

# Comma-separated channel IDs to watch (right-click channel with Developer Mode on)
DISCORD_CHANNEL_IDS=1234567890123456789,9876543210987654321

# Map channel IDs or names to analyst names (channel_id_or_name:trader_name,...)
# The Windows watcher sees channel NAMES (from toast), the bot sees channel IDs.
# You can add both so both ingestion paths work:
CHANNEL_ANALYST_MAP=1234567890123456789:Grizzlies,grizzlies-signals:Grizzlies,9876543210987654321:ECS
